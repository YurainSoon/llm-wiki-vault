# OS / editor noise
.DS_Store
.obsidian/

# Claude Code: per-user settings & session state
.claude/settings.local.json
.claude/settings.json
.claude/projects/

# Anthropic-distributed skills (don't republish — only commit ours via the symlink)
.claude/skills/*
!.claude/skills/triage

# Future user-added agents — only commit the published one
.claude/agents/*
!.claude/agents/triage-classifier.md

# Inbox: keep dir as scaffolding, ignore contents
Clippings/*
!Clippings/.gitkeep

# Subdomain folders are private — the folders themselves do not appear in the
# repo at all (not just their contents). Published skills live under skills/ at
# the root, so they are unaffected by this.
/life/
/research/
/interview-prep/
